---
import BaseLayout from '../../../components/BaseLayout.astro';
import ProjectCard from '../../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../../../i18n/utils';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'id' } },
    { params: { lang: 'ja' } },
  ];
}

const { lang } = Astro.params;
const t = useTranslations(lang as any);

// Get all projects and filter by current language
const allProjects = await getCollection('projects');
const langProjects = allProjects
  .filter((project) => project.id.endsWith(`/${lang}.md`) || project.id.endsWith(`/${lang}`))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Collect all unique tags
const allTags = [...new Set(langProjects.flatMap((project) => project.data.tags))];
---

<BaseLayout title={`${t('projectsTitle')} — ${t('siteTitle')}`} description={t('projectsDescription')} lang={lang as any}>
  <div class="bg-surface-container-low min-h-[calc(100vh-6rem)]">
    {/* Page Header */}
    <div class="max-w-4xl mx-auto px-8 pt-16 pb-12 pl-12 md:pl-24">
      {/* Margin label */}
      <div class="font-label text-[10px] uppercase tracking-[0.2em] text-outline-variant mb-6 flex items-center gap-2">
        <span class="w-1.5 h-1.5 bg-primary"></span>
        [ PORTFOLIO_v1.0 ]
      </div>

      {/* Title */}
      <h1 class="font-display text-5xl md:text-6xl font-light tracking-tight text-on-surface mb-4">
        {t('projectsTitle')}
      </h1>

      {/* Description */}
      <p class="font-body text-base text-on-surface-variant leading-relaxed max-w-lg">
        {t('projectsDescription')}
      </p>
    </div>

    {/* Tag Filter */}
    {allTags.length > 0 && (
      <div class="max-w-4xl mx-auto px-8 pl-12 md:pl-24 pb-8">
        <div class="flex flex-wrap gap-2 items-center" id="tag-filter">
          <span class="font-label text-[9px] uppercase tracking-[0.1em] text-outline mr-2">{t('filterByStack')}:</span>
          <button
            data-tag="all"
            class="tag-btn font-label text-[10px] uppercase tracking-[0.05em] px-3 py-1 bg-primary text-on-primary mechanical-flicker-100ms cursor-pointer"
          >
            All
          </button>
          {allTags.map((tag) => (
            <button
              data-tag={tag}
              class="tag-btn font-label text-[10px] uppercase tracking-[0.05em] px-3 py-1 bg-surface-container-lowest text-on-surface-variant border border-outline-variant/15 hover:bg-primary hover:text-on-primary mechanical-flicker-100ms cursor-pointer"
            >
              {tag}
            </button>
          ))}
        </div>
      </div>
    )}

    {/* Project List */}
    <div class="max-w-4xl mx-auto px-8 pl-12 md:pl-24 pb-24">
      {langProjects.length === 0 ? (
        <div class="py-24 text-center">
          <p class="font-body text-on-surface-variant">{t('noProjects')}</p>
        </div>
      ) : (
        <div class="flex flex-col gap-6" id="project-list">
          {langProjects.map((project) => {
            const slug = project.id.split('/')[0];
            return (
              <div class="project-card-wrapper" data-tags={JSON.stringify(project.data.tags)}>
                <ProjectCard
                  title={project.data.title}
                  date={project.data.date}
                  description={project.data.description}
                  tags={project.data.tags}
                  thumbnail={project.data.thumbnail}
                  externalUrl={project.data.externalUrl}
                  slug={slug}
                  lang={lang!}
                  visitSiteLabel={t('visitSite')}
                />
              </div>
            );
          })}
        </div>
      )}
    </div>
  </div>

  {/* Client-side tag filtering */}
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const buttons = document.querySelectorAll('.tag-btn');
      const cards = document.querySelectorAll('.project-card-wrapper');

      buttons.forEach((btn) => {
        btn.addEventListener('click', () => {
          const tag = (btn as HTMLElement).dataset.tag;

          // Update button styles
          buttons.forEach((b) => {
            b.classList.remove('bg-primary', 'text-on-primary');
            b.classList.add('bg-surface-container-lowest', 'text-on-surface-variant', 'border', 'border-outline-variant/15');
          });
          btn.classList.remove('bg-surface-container-lowest', 'text-on-surface-variant', 'border', 'border-outline-variant/15');
          btn.classList.add('bg-primary', 'text-on-primary');

          // Filter cards
          cards.forEach((card) => {
            const cardTags = JSON.parse((card as HTMLElement).dataset.tags || '[]');
            if (tag === 'all' || cardTags.includes(tag)) {
              (card as HTMLElement).style.display = '';
            } else {
              (card as HTMLElement).style.display = 'none';
            }
          });
        });
      });
    });
  </script>
</BaseLayout>
