---
import BaseLayout from '../../components/BaseLayout.astro';
import ContactForm from '../../components/ContactForm.astro';
import { useTranslations } from '../../i18n/utils';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'id' } },
    { params: { lang: 'ja' } },
  ];
}

const { lang } = Astro.params;
const t = useTranslations(lang as any);
---

<BaseLayout title={`${t('contactTitle')} | ${t('siteTitle')}`} description={t('contactDescription')} lang={lang as any}>
  <div class="contact-page fade-in">
    <header class="page-header">
      <h1 class="page-title">{t('contactTitle')}</h1>
      <p class="page-description">{t('contactDescription')}</p>
    </header>

    <div class="form-wrapper">
      <ContactForm lang={lang as any} />
    </div>
  </div>
</BaseLayout>

<style>
  .contact-page {
    max-width: var(--content-max);
    margin: 0 auto;
    padding: var(--space-3xl) var(--space-xl);
    min-height: calc(100vh - var(--header-height) - 100px);
  }

  .page-header {
    margin-bottom: var(--space-3xl);
    text-align: center;
  }

  .page-title {
    font-family: var(--font-headline);
    font-size: 3.5rem;
    font-weight: 700;
    color: var(--header-bg);
    margin-bottom: var(--space-sm);
    letter-spacing: -0.02em;
  }

  .page-description {
    font-family: var(--font-body);
    font-style: italic;
    color: var(--text-muted);
    font-size: 1.2rem;
    max-width: 500px;
    margin: 0 auto;
  }

  .form-wrapper {
    background-color: var(--card-bg);
    padding: var(--space-2xl);
    border: 1px solid var(--border);
    box-shadow: 4px 4px 0px var(--border);
  }

  .fade-in {
    animation: fadeIn 0.6s ease-out;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 768px) {
    .contact-page {
       padding: var(--space-xl) var(--space-md);
    }
    .page-title {
      font-size: 2.5rem;
    }
    .form-wrapper {
      padding: var(--space-lg);
    }
  }
</style>
