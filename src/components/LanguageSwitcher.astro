---
import { getRelativeLocaleUrl } from 'astro:i18n';

interface Props {
  currentLang: 'en' | 'id' | 'ja';
}
const { currentLang } = Astro.props;

const locales = [
  { code: 'en', label: 'English' },
  { code: 'id', label: 'Indonesian' },
  { code: 'ja', label: 'Japanese' }
];
---
<nav class="font-headline uppercase tracking-widest text-sm flex gap-2 text-outline items-center bg-transparent">
  {locales.map((locale, index) => (
    <>
      <a 
        href={getRelativeLocaleUrl(locale.code)}
        class={`hover:text-primary transition-colors mechanical-flicker-100ms ${locale.code === currentLang ? 'text-primary font-bold border-b border-primary' : ''}`}
      >
        {locale.code.toUpperCase()}
      </a>
      {index < locales.length - 1 && <span>/</span>}
    </>
  ))}
</nav>
