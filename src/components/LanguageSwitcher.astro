---
import { getRelativeLocaleUrl } from 'astro:i18n';

interface Props {
  currentLang: 'en' | 'id' | 'ja';
}
const { currentLang } = Astro.props;

const locales = [
  { code: 'en', label: 'EN' },
  { code: 'id', label: 'ID' },
  { code: 'ja', label: 'JA' },
] as const;

const pathname = Astro.url.pathname;
const pathWithoutLang = pathname.replace(new RegExp(`^/${currentLang}/?`), '');
---
<nav class="lang-switcher" aria-label="Language switcher">
  {locales.map(locale => (
    <a
      href={getRelativeLocaleUrl(locale.code, pathWithoutLang)}
      class={locale.code === currentLang ? 'active' : ''}
      aria-current={locale.code === currentLang ? 'true' : undefined}
      lang={locale.code}
    >
      {locale.label}
    </a>
  ))}
</nav>
