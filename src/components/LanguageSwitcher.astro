---
interface Props {
    currentLang: 'en' | 'id' | 'ja';
}
const {currentLang} = Astro.props;

const locales = [
    {code: 'id', label: 'Indonesian', country: 'id'},
    {code: 'en', label: 'English', country: 'gb'},
    {code: 'ja', label: 'Japanese', country: 'jp'}
];

// Build a locale-swapped URL for the current page.
const currentPath = Astro.url.pathname;
function switchLang(targetLang: string): string {
    return currentPath.replace(/^\/[a-z]{2}(\/|$)/, `/${targetLang}$1`);
}
---
<nav class="flex gap-4 items-center bg-transparent">
    {locales.map((locale) => (
            <a
                    href={switchLang(locale.code)}
                    title={locale.label}
                    class={`w-6 h-4 overflow-hidden transition-all duration-300 hover:scale-110 mechanical-flicker-100ms ${locale.code === currentLang ? 'grayscale-0 scale-110 ring-1 ring-primary/30' : 'grayscale opacity-50 hover:grayscale-0 hover:opacity-100'}`}
            >
                <img
                        src={`https://flagcdn.com/${locale.country}.svg`}
                        alt={locale.label}
                        class="w-full h-full object-cover border-2"
                        loading="lazy"
                />
            </a>
    ))}
</nav>
