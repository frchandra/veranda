---
interface Props {
  currentLang: 'en' | 'id' | 'ja';
}
const { currentLang } = Astro.props;

const locales = [
  { code: 'en', label: 'English', flag: '🇬🇧' },
  { code: 'id', label: 'Indonesian', flag: '🇮🇩' },
  { code: 'ja', label: 'Japanese', flag: '🇯🇵' }
];

// Build a locale-swapped URL for the current page.
// e.g. /en/blog/hello-world/ → /ja/blog/hello-world/
const currentPath = Astro.url.pathname;
function switchLang(targetLang: string): string {
  // The path always starts with /{lang}/...
  // Replace the first path segment (the lang code) with the target lang.
  return currentPath.replace(/^\/[a-z]{2}(\/|$)/, `/${targetLang}$1`);
}
---
<nav class="flex gap-4 items-center bg-transparent">
  {locales.map((locale) => (
    <a 
      href={switchLang(locale.code)}
      title={locale.label}
      class={`text-xl hover:scale-110 transition-transform mechanical-flicker-100ms ${locale.code === currentLang ? 'grayscale-0' : 'grayscale opacity-60 hover:grayscale-0 hover:opacity-100'}`}
    >
      {locale.flag}
    </a>
  ))}
</nav>
