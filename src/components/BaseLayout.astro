---
import SEOHead from './SEOHead.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  lang: 'en' | 'id' | 'ja';
}
const { title, description, lang } = Astro.props;
---
<html lang={lang}>
  <head>
    <SEOHead title={title} description={description} />
  </head>
  <body class="bg-white text-slate-900 dark:bg-slate-900 dark:text-white max-w-4xl mx-auto p-8 font-sans">
    <header class="flex justify-between items-center mb-12">
      <nav class="flex gap-4">
        <a href={`/${lang}/`} class="hover:underline">Home</a>
        <a href={`/${lang}/blog/`} class="hover:underline">Blog</a>
      </nav>
      <LanguageSwitcher currentLang={lang} />
    </header>
    
    <main>
      <slot />
    </main>

    <footer class="mt-20 text-sm text-slate-500 text-center">
      &copy; {new Date().getFullYear()} Veranda
    </footer>
  </body>
</html>
