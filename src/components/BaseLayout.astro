---
import SEOHead from './SEOHead.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { useTranslations } from '../i18n/utils';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  lang: 'en' | 'id' | 'ja';
  isLobby?: boolean;
}

const { title, description, lang, isLobby = false } = Astro.props;
const t = useTranslations(lang);
---
<html lang={lang}>
  <head>
    <SEOHead title={title} description={description} />
  </head>
  <body>
    <header class="site-header">
      <a href={`/${lang}/`} class="site-brand">Veranda</a>

      <nav class="site-nav" aria-label="Primary navigation">
        <a href={`/${lang}/blog/`}>{t('navBlog')}</a>
        <a href={`/${lang}/projects/`}>{t('navProjects')}</a>
        <a href={`/${lang}/gallery/`}>{t('navGallery')}</a>
        <a href={`/${lang}/contact/`}>{t('navContact')}</a>
      </nav>

      <div class="header-right">
        <LanguageSwitcher currentLang={lang} />
      </div>
    </header>

    <main>
      <slot />
    </main>

    {!isLobby && (
      <footer class="site-footer">
        &copy; {new Date().getFullYear()} {t('footerCopy')}
      </footer>
    )}
  </body>
</html>
