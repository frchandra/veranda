---
import { useTranslations } from '../i18n/utils';

interface Props {
  slug: string;
  currentLang: 'en' | 'id' | 'ja';
  availableLangs: string[];
}

const { slug, currentLang, availableLangs } = Astro.props;
const t = useTranslations(currentLang);

const langNames: Record<string, string> = {
  en: 'English',
  id: 'Bahasa Indonesia',
  ja: '日本語',
};
---

<div class="max-w-[65ch] mx-auto px-6 py-24">
  <div class="bg-surface-container-lowest border-l-2 border-primary p-8 shadow-[0px_4px_20px_rgba(45,52,53,0.06)]">
    {/* Label */}
    <div class="font-label text-[10px] uppercase tracking-[0.2em] text-primary mb-4 flex items-center gap-2">
      <span class="w-2 h-2 bg-primary"></span>
      {t('notAvailableTitle')}
    </div>

    {/* Message */}
    <p class="font-body text-base text-on-surface-variant leading-relaxed mb-8">
      {t('notAvailableMessage')}
    </p>

    {/* Available languages */}
    <div class="mb-6">
      <span class="font-label text-[10px] uppercase tracking-[0.1em] text-outline mb-3 block">
        {t('availableIn')}:
      </span>
      <div class="flex flex-wrap gap-3 mt-2">
        {availableLangs.map((lang) => (
          <a
            href={`/${lang}/blog/${slug}/`}
            class="inline-flex items-center gap-2 bg-primary text-on-primary px-4 py-2 font-headline text-xs uppercase tracking-widest mechanical-flicker-100ms hover:bg-primary-dim transition-colors"
          >
            {langNames[lang] || lang.toUpperCase()}
            <span class="material-symbols-outlined text-sm">arrow_forward</span>
          </a>
        ))}
      </div>
    </div>

    {/* Back to blog */}
    <a
      href={`/${currentLang}/blog/`}
      class="inline-flex items-center gap-2 font-headline text-[11px] uppercase tracking-[0.1em] text-outline-variant hover:text-primary transition-colors"
    >
      <span class="material-symbols-outlined text-sm">arrow_back</span>
      {t('allPosts')}
    </a>
  </div>
</div>
